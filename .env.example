# OpenAI API key — used for GPT-Image-1 generation, GPT-3.5-Turbo reformulation, GPT-4o judge
OPENAI_API_KEY=sk-...

# Google AI Studio key — used for Gemini 2.0 Flash image generation
GOOGLE_API_KEY=AIza...

# Optional: HuggingFace token for gated models
HF_TOKEN=hf_...

# Optional: override model IDs
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_REFORMULATOR_MODEL=gpt-3.5-turbo
OPENAI_JUDGE_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash-exp
SDXL_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
